# nanogent secrets. Copy to .env (which is gitignored via .nanogent/.gitignore).
# Non-secret settings live in .nanogent/config.json instead.

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Get a token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to talk to this bot.
# Message @userinfobot on Telegram to find yours.
# Leave empty to allow anyone who knows the bot (NOT recommended).
TELEGRAM_ALLOWED_CHAT_IDS=

# ---------------------------------------------------------------------------
# Anthropic (powers the chat agent — the layer that routes messages to tools)
# ---------------------------------------------------------------------------

# Required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

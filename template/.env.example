# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to talk to this project.
# Easiest way to find yours: message @userinfobot on Telegram.
# Leave empty to allow anyone who knows the bot (NOT recommended).
TELEGRAM_ALLOWED_CHAT_IDS=

# ---------------------------------------------------------------------------
# Anthropic (for the chat agent that routes messages to tools)
# ---------------------------------------------------------------------------

# Required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional — default is claude-haiku-4-5 (cheap + fast, right for routing).
# Override to claude-sonnet-4-5 or claude-opus-4-6 for smarter chat at higher cost.
# NANOGENT_CHAT_MODEL=claude-haiku-4-5

# Optional — max tokens the chat agent can generate per turn. Default 1024.
# NANOGENT_MAX_TOKENS=1024

# Optional — how many messages of history to keep. Older turns are dropped on rotation.
# NANOGENT_MAX_HISTORY=80
